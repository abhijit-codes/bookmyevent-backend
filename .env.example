NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:5173
VITE_API_URL=http://localhost:5000/api/v1
VITE_RAZORPAY_KEY_ID=replace-with-razorpay-key-id

DB_HOST=localhost
DB_USER=root
DB_PASSWORD=replace-with-local-password
DB_NAME=BookMyEvent
DB_PORT=3306
DB_DIALECT=mysql

JWT_ACCESS_SECRET=replace-with-long-random-secret
JWT_REFRESH_SECRET=replace-with-another-long-random-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=replace-with-email
EMAIL_PASS=replace-with-app-password
EMAIL_FROM="BookMyEvent <no-reply@bookmyevent.local>"

RAZORPAY_KEY_ID=replace-with-razorpay-key
RAZORPAY_KEY_SECRET=replace-with-razorpay-secret
ADMIN_UPI_ID=replace-with-admin-upi

CLOUDINARY_CLOUD_NAME=replace-with-cloud-name
CLOUDINARY_API_KEY=replace-with-cloudinary-key
CLOUDINARY_API_SECRET=replace-with-cloudinary-secret

MAPBOX_ACCESS_TOKEN=replace-with-mapbox-token
GEOAPIFY_API_KEY=replace-with-geoapify-key-if-using-geoapify
GOOGLE_CLIENT_ID=replace-with-google-client-id

BANK_ACCOUNT_ENCRYPTION_KEY=replace-with-64-hex-character-key
ADMIN_COMMISSION_PERCENT=10
PLATFORM_FEE=500
ADVANCE_AMOUNT=1000
PAYMENT_DUE_HOURS=48
